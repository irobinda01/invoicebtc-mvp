# InvoiceBTC MVP - Stacks public testnet configuration.
# This app targets Stacks public testnet only.
# Copy this file to .env.local for local frontend runs.

# Stacks public testnet API (Hiro)
NEXT_PUBLIC_STACKS_API_BASE=https://api.testnet.hiro.so

# Deployed InvoiceBTC contract on testnet.
NEXT_PUBLIC_CONTRACT_ADDRESS=ST1YBHMDH6ESJ1DBY8MK72XER9BG9646QMCS610PE
NEXT_PUBLIC_CONTRACT_NAME=invoicebtc-v4

# Testnet sBTC SIP-010 token contract used for escrow deposits and balance reads.
NEXT_PUBLIC_SBTC_CONTRACT_ADDRESS=ST1F7QA2MDF17S807EPA36TSS8AMEFY4KA9TVGWXT

# Hiro explorer bases. The frontend always appends ?chain=testnet.
NEXT_PUBLIC_EXPLORER_BASE=https://explorer.hiro.so/txid
NEXT_PUBLIC_EXPLORER_ADDRESS_BASE=https://explorer.hiro.so/address
